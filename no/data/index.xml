    <item>
      <title>Einfaches plotly</title>
      <link>http://localhost:1313/no/data/plotly_demo/</link>
      <pubDate>Tue, 25 Feb 2025 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/no/data/plotly_demo/</guid>
      <description>&lt;head&gt;
  &lt;!-- Plotly.js --&gt;
  &lt;script src=&#34;https://cdn.plot.ly/plotly-latest.min.js&#34;&gt;&lt;/script&gt;
&lt;/head&gt;

&lt;p&gt;
  Einfaches &lt;a href=&#34;https://bit.ly/1Or9igj&#34;&gt;plotly.js&lt;/a&gt; Demo
&lt;/p&gt;
&lt;div id=&#34;myDiv&#34;&gt;&lt;/div&gt;
&lt;script&gt;
    var trace1 = {
        x: [1, 2, 3, 4],
        y: [10, 11, 12, 13],
        text: [&#39;A&lt;br&gt;Größe: 40&#39;, &#39;B&lt;br&gt;Größe: 60&#39;, &#39;C&lt;br&gt;Größe: 80&#39;, &#39;D&lt;br&gt;Größe: 100&#39;],
        mode: &#39;markers&#39;,
        marker: {
          size: [400, 600, 800, 1000],
          sizemode: &#39;area&#39;
        }
      };
      
      var trace2 = {
        x: [1, 2, 3, 4],
        y: [14, 15, 16, 17],
        text: [&#39;A&lt;/br&gt;Größe: 40&lt;/br&gt;sixeref: 0.2&#39;, &#39;B&lt;/br&gt;Größe: 60&lt;/br&gt;sixeref: 0.2&#39;, &#39;C&lt;/br&gt;Größe: 80&lt;/br&gt;sixeref: 0.2&#39;, &#39;D&lt;/br&gt;Größe: 100&lt;/br&gt;sixeref: 0.2&#39;],
        mode: &#39;markers&#39;,
        marker: {
          size: [400, 600, 800, 1000],
          // Das Setzen von &#39;sizeref&#39; auf einen Wert unter 1 verringert die dargestellte Größe
          sizeref: 2,
          sizemode: &#39;area&#39;
        }
      };
      
      var trace3 = {
        x: [1, 2, 3, 4],
        y: [20, 21, 22, 23],
        text: [&#39;A&lt;/br&gt;Größe: 40&lt;/br&gt;sixeref: 2&#39;, &#39;B&lt;/br&gt;Größe: 60&lt;/br&gt;sixeref: 2&#39;, &#39;C&lt;/br&gt;Größe: 80&lt;/br&gt;sixeref: 2&#39;, &#39;D&lt;/br&gt;Größe: 100&lt;/br&gt;sixeref: 2&#39;],
        mode: &#39;markers&#39;,
        marker: {
          size: [400, 600, 800, 1000],
          // Das Setzen von &#39;sizeref&#39; auf einen Wert unter 1 vergrößert die dargestellten Markergrößen
          sizeref: 0.2,
          sizemode: &#39;area&#39;
        }
      };
      
      // Berechnung des korrekten &#39;sizeref&#39; mit der obigen Formel
      var desired_maximum_marker_size = 40;
      var size = [400, 600, 800, 1000];
      var trace4 = {
        x: [1, 2, 3, 4],
        y: [26, 27, 28, 29],
        text: [&#39;A&lt;/br&gt;Größe: 40&lt;/br&gt;sixeref: 1.25&#39;, &#39;B&lt;/br&gt;Größe: 60&lt;/br&gt;sixeref: 1.25&#39;, &#39;C&lt;/br&gt;Größe: 80&lt;/br&gt;sixeref: 1.25&#39;, &#39;D&lt;/br&gt;Größe: 100&lt;/br&gt;sixeref: 1.25&#39;],
        mode: &#39;markers&#39;,
        marker: {
          size: size,
          // Berechne &#39;sizeref&#39; mit: 2.0 * max(array_of_size_values) / (desired_maximum_marker_size^2)
          sizeref: 2.0 * Math.max(...size) / (desired_maximum_marker_size**2),
          sizemode: &#39;area&#39;
        }
      };
      
      var data = [trace1, trace2, trace3, trace4];
      
      var layout = {
        title: {
          text: &#39;Größenanpassung in Blasendiagrammen&#39;
        },
        showlegend: false,
        height: 600,
        width: 1200,
        paper_bgcolor: &#39;rgba(0,0,0,0)&#39;,
        plot_bgcolor: &#39;rgba(0,0,0,0)&#39;
      };
      
      Plotly.newPlot(&#39;myDiv&#39;, data, layout);
&lt;/script&gt;</description>
