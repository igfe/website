    <item>
      <title>Eenvoudige plotly</title>
      <link>http://localhost:1313/nl/data/plotly_demo/</link>
      <pubDate>Tue, 25 Feb 2025 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/nl/data/plotly_demo/</guid>
      <description>&lt;head&gt;
  &lt;!-- Plotly.js --&gt;
  &lt;script src=&#34;https://cdn.plot.ly/plotly-latest.min.js&#34;&gt;&lt;/script&gt;
&lt;/head&gt;
&lt;p&gt;
  Eenvoudige &lt;a href=&#34;https://bit.ly/1Or9igj&#34;&gt;plotly.js&lt;/a&gt; demo
&lt;/p&gt;
&lt;div id=&#34;myDiv&#34;&gt;&lt;/div&gt;
&lt;script&gt;
    var trace1 = {
        x: [1, 2, 3, 4],
        y: [10, 11, 12, 13],
        text: [&#39;A&lt;br&gt;grootte: 40&#39;, &#39;B&lt;br&gt;grootte: 60&#39;, &#39;C&lt;br&gt;grootte: 80&#39;, &#39;D&lt;br&gt;grootte: 100&#39;],
        mode: &#39;markers&#39;,
        marker: {
          size: [400, 600, 800, 1000],
          sizemode: &#39;area&#39;
        }
      };
&lt;pre&gt;&lt;code&gt;  var trace2 = {
    x: [1, 2, 3, 4],
    y: [14, 15, 16, 17],
    text: [&#39;A&amp;lt;/br&amp;gt;grootte: 40&amp;lt;/br&amp;gt;sixeref: 0.2&#39;, &#39;B&amp;lt;/br&amp;gt;grootte: 60&amp;lt;/br&amp;gt;sixeref: 0.2&#39;, &#39;C&amp;lt;/br&amp;gt;grootte: 80&amp;lt;/br&amp;gt;sixeref: 0.2&#39;, &#39;D&amp;lt;/br&amp;gt;grootte: 100&amp;lt;/br&amp;gt;sixeref: 0.2&#39;],
    mode: &#39;markers&#39;,
    marker: {
      size: [400, 600, 800, 1000],
      // Het instellen van &#39;sizeref&#39; lager dan 1 verkleint de getoonde grootte
      sizeref: 2,
      sizemode: &#39;area&#39;
    }
  };
  
  var trace3 = {
    x: [1, 2, 3, 4],
    y: [20, 21, 22, 23],
    text: [&#39;A&amp;lt;/br&amp;gt;grootte: 40&amp;lt;/br&amp;gt;sixeref: 2&#39;, &#39;B&amp;lt;/br&amp;gt;grootte: 60&amp;lt;/br&amp;gt;sixeref: 2&#39;, &#39;C&amp;lt;/br&amp;gt;grootte: 80&amp;lt;/br&amp;gt;sixeref: 2&#39;, &#39;D&amp;lt;/br&amp;gt;grootte: 100&amp;lt;/br&amp;gt;sixeref: 2&#39;],
    mode: &#39;markers&#39;,
    marker: {
      size: [400, 600, 800, 1000],
      // Het instellen van &#39;sizeref&#39; op minder dan 1 vergroot de getoonde marker-groottes
      sizeref: 0.2,
      sizemode: &#39;area&#39;
    }
  };
  
  // Bereken de juiste &#39;sizeref&#39; met de bovenstaande formule
  var desired_maximum_marker_size = 40;
  var size = [400, 600, 800, 1000];
  var trace4 = {
    x: [1, 2, 3, 4],
    y: [26, 27, 28, 29],
    text: [&#39;A&amp;lt;/br&amp;gt;grootte: 40&amp;lt;/br&amp;gt;sixeref: 1.25&#39;, &#39;B&amp;lt;/br&amp;gt;grootte: 60&amp;lt;/br&amp;gt;sixeref: 1.25&#39;, &#39;C&amp;lt;/br&amp;gt;grootte: 80&amp;lt;/br&amp;gt;sixeref: 1.25&#39;, &#39;D&amp;lt;/br&amp;gt;grootte: 100&amp;lt;/br&amp;gt;sixeref: 1.25&#39;],
    mode: &#39;markers&#39;,
    marker: {
      size: size,
      // Bereken de ideale &#39;sizeref&#39; met de formule: 2.0 * max(array_of_size_values) / (desired_maximum_marker_size^2)
      sizeref: 2.0 * Math.max(...size) / (desired_maximum_marker_size**2),
      sizemode: &#39;area&#39;
    }
  };
  
  var data = [trace1, trace2, trace3, trace4];
  
  var layout = {
    title: {
      text: &#39;Schaalverdeling in bubbelgrafieken&#39;
    },
    showlegend: false,
    height: 600,
    width: 1200,
    paper_bgcolor: &#39;rgba(0,0,0,0)&#39;,
    plot_bgcolor: &#39;rgba(0,0,0,0)&#39;
  };
  
  Plotly.newPlot(&#39;myDiv&#39;, data, layout);
&lt;/code&gt;&lt;/pre&gt;
&lt;p&gt;&lt;/script&gt;&lt;/p&gt;</description>
    </item>
    <item>
      <title>$ whoami</title>
      <link>http://localhost:1313/nl/posts/whoami/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/nl/posts/whoami/</guid>
      <description>&lt;p&gt;Ik ben een dataprofessional met een passie voor de toekomst. Hoewel ik het grootste deel van mijn werktijd besteed aan het bewerken van YAML-configuratiebestanden, ligt mijn diepere passie bij computationele analyse en datavisualisatie.&lt;/p&gt;
&lt;p&gt;Ik maak veel gebruik van moderne LLM&amp;rsquo;s om mijn werk te doen, terwijl ik er tegelijkertijd voor zorg dat ik echte vaardigheden ontwikkel en niet al mijn denkwerk uitbesteed aan een robot.&lt;/p&gt;
&lt;p&gt;Mijn hobby&amp;rsquo;s zijn fitness (hardlopen en mountainbiken), aandelenhandel, het spelen van videogame-soundtracks op klassieke gitaar, en aangevallen worden door een kleine mens.&lt;/p&gt;</description>
    </item>
